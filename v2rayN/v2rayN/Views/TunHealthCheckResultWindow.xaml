<Window
    x:Class="v2rayN.Views.TunHealthCheckResultWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:ServiceLib.Resx;assembly=ServiceLib"
    Title="{x:Static resx:ResUI.TunHealthCheckTitle}"
    Width="680"
    Height="600"
    MinWidth="500"
    MinHeight="400"
    WindowStartupLocation="CenterScreen"
    Style="{StaticResource WindowGlobal}"
    mc:Ignorable="d">
    <DockPanel Margin="{StaticResource Margin8}">
        <StackPanel
            Margin="{StaticResource Margin4}"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <Button
                x:Name="btnCopy"
                Width="100"
                Margin="{StaticResource MarginLeftRight8}"
                Content="复制报告"
                Style="{StaticResource DefButton}" />
            <Button
                x:Name="btnExport"
                Width="100"
                Margin="{StaticResource MarginLeftRight8}"
                Content="导出 JSON"
                Style="{StaticResource DefButton}" />
            <Button
                x:Name="btnClose"
                Width="100"
                Content="关闭"
                IsCancel="True"
                Style="{StaticResource DefButton}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <materialDesign:Card
                    x:Name="cardOverall"
                    Margin="{StaticResource Margin4}"
                    Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="txtOverallStatus"
                            Grid.Row="0"
                            Grid.Column="0"
                            FontSize="20"
                            FontWeight="Bold"
                            VerticalAlignment="Center" />
                        <TextBlock
                            x:Name="txtDuration"
                            Grid.Row="0"
                            Grid.Column="2"
                            FontSize="14"
                            Foreground="Gray"
                            VerticalAlignment="Center" />
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,8,0,0"
                            Orientation="Horizontal">
                            <TextBlock
                                x:Name="txtScoreLabel"
                                FontSize="14"
                                Foreground="Gray" />
                            <TextBlock
                                x:Name="txtScore"
                                FontSize="14"
                                FontWeight="Bold"
                                Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <ItemsControl
                    x:Name="lstLayers"
                    Margin="{StaticResource Margin4}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card
                                Margin="0,0,0,8"
                                Padding="12">
                                <Expander IsExpanded="{Binding IsExpanded}">
                                    <Expander.Header>
                                        <DockPanel>
                                            <Ellipse
                                                Width="12"
                                                Height="12"
                                                Margin="0,0,8,0"
                                                Fill="{Binding StatusColor}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Text="{Binding LayerName}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Margin="12,0,0,0"
                                                Foreground="Gray"
                                                Text="{Binding StatusText}"
                                                VerticalAlignment="Center" />
                                            <TextBlock
                                                Margin="12,0,0,0"
                                                Foreground="Gray"
                                                FontSize="12"
                                                Text="{Binding Duration}"
                                                VerticalAlignment="Center" />
                                        </DockPanel>
                                    </Expander.Header>
                                    <ItemsControl
                                        Margin="24,4,0,0"
                                        ItemsSource="{Binding Details}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel
                                                    Margin="0,2"
                                                    Orientation="Horizontal">
                                                    <TextBlock
                                                        Width="200"
                                                        Foreground="Gray"
                                                        Text="{Binding Key}" />
                                                    <TextBlock Text="{Binding Value}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <materialDesign:Card
                    x:Name="cardDiagnosis"
                    Margin="{StaticResource Margin4}"
                    Padding="12"
                    Visibility="Collapsed">
                    <DockPanel>
                        <TextBlock
                            DockPanel.Dock="Top"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Margin="0,0,0,8"
                            Text="自动诊断建议" />
                        <ItemsControl x:Name="lstDiagnosis">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,4"
                                        Padding="8"
                                        Background="#FFF3E0"
                                        CornerRadius="4">
                                        <TextBlock
                                            Text="{Binding}"
                                            TextWrapping="Wrap"
                                            Foreground="#E65100" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
