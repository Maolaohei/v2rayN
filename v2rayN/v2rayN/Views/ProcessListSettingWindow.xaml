<Window
    x:Class="v2rayN.Views.ProcessListSettingWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resx="clr-namespace:ServiceLib.Resx;assembly=ServiceLib"
    Title="{x:Static resx:ResUI.ProcessListSettingTitle}"
    Width="550"
    Height="640"
    MinWidth="450"
    MinHeight="540"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <DockPanel Margin="{StaticResource Margin8}">
        <StackPanel
            Margin="{StaticResource Margin4}"
            HorizontalAlignment="Right"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">
            <Button
                x:Name="btnOk"
                Width="100"
                Click="BtnOk_Click"
                Content="{x:Static resx:ResUI.TbConfirm}"
                IsDefault="True"
                Style="{StaticResource DefButton}" />
            <Button
                x:Name="btnCancel"
                Width="100"
                Margin="{StaticResource MarginLeftRight8}"
                Content="{x:Static resx:ResUI.TbCancel}"
                IsCancel="true"
                Style="{StaticResource DefButton}" />
        </StackPanel>

        <CheckBox
            x:Name="chkDnsViaBridge"
            Margin="{StaticResource Margin4}"
            DockPanel.Dock="Bottom"
            Content="{x:Static resx:ResUI.ProcessListDnsViaBridge}" />

        <TextBlock
            x:Name="txtStatus"
            Margin="{StaticResource Margin4}"
            DockPanel.Dock="Bottom"
            FontSize="12"
            Foreground="Gray"
            Text="当前生效: 0 个进程" />

        <Border
            Margin="{StaticResource Margin4}"
            DockPanel.Dock="Top"
            Padding="8"
            BorderBrush="LightGray"
            BorderThickness="1"
            CornerRadius="4"
            Background="#F5F5F5">
            <StackPanel>
                <TextBlock
                    Margin="0,0,0,4"
                    FontWeight="Bold"
                    Text="驱动状态" />
                <StackPanel Margin="16,0,0,0">
                    <TextBlock x:Name="txtDriverFile" Text="• 驱动文件: 检查中..." />
                    <TextBlock x:Name="txtDriverService" Text="• 驱动服务: 检查中..." />
                    <TextBlock x:Name="txtNetBridgeStatus" Text="• NetBridge: 检查中..." />
                    <StackPanel
                        Margin="0,4,0,0"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="转发模式:" />
                        <ComboBox
                            x:Name="cmbForwardMode"
                            Width="160"
                            VerticalAlignment="Center"
                            SelectionChanged="CmbForwardMode_SelectionChanged">
                            <ComboBoxItem Content="中转模式 (Bridge)" Tag="Bridge" IsSelected="True" />
                            <ComboBoxItem Content="协议直连 (CoreDirect)" Tag="CoreDirect" />
                            <ComboBoxItem Content="兼容模式 (Legacy)" Tag="Legacy" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel
                        Margin="0,4,0,0"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Text="• 协议模式:" />
                        <RadioButton
                            x:Name="rbProtocolTcp"
                            Margin="0,0,4,0"
                            Content="TCP"
                            GroupName="ProtocolMode"
                            IsChecked="True"
                            VerticalAlignment="Center" />
                        <RadioButton
                            x:Name="rbProtocolUdp"
                            Margin="0,0,4,0"
                            Content="UDP"
                            GroupName="ProtocolMode"
                            VerticalAlignment="Center" />
                        <RadioButton
                            x:Name="rbProtocolBoth"
                            Margin="0,0,0,0"
                            Content="TCP+UDP"
                            GroupName="ProtocolMode"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <TabControl
            x:Name="tabControl"
            Margin="0,4,0,0">
            <TabItem Header="{x:Static resx:ResUI.ProcessListRunning}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="txtSearch"
                                Grid.Column="0"
                                VerticalContentAlignment="Center"
                                TextChanged="TxtSearch_TextChanged"
                                KeyDown="TxtSearch_KeyDown" />
                            <TextBlock
                                x:Name="txtSearchWatermark"
                                Grid.Column="0"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                IsHitTestVisible="False"
                                Foreground="Gray"
                                FontSize="12"
                                Text="搜索进程名或应用名" />
                        </Grid>
                        <Button
                            x:Name="btnRefresh"
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="8,4"
                            Content="🔄 刷新" />
                    </Grid>
                    <StackPanel
                        DockPanel.Dock="Top"
                        Margin="0,0,0,4"
                        Orientation="Horizontal">
                        <CheckBox
                            x:Name="chkSelectAll"
                            Margin="0,0,8,0"
                            Content="全选/取消全选"
                            VerticalAlignment="Center" />
                        <Button
                            x:Name="btnAddSelected"
                            Padding="8,4"
                            Content="{x:Static resx:ResUI.ProcessListAddSelected}" />
                    </StackPanel>
                    <ListBox
                        x:Name="lstProcesses"
                        BorderThickness="1"
                        MaxHeight="280"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <Image
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Source="{Binding Icon}"
                                        ToolTip="{Binding Name}" />
                                    <CheckBox
                                        Margin="0"
                                        Content="{Binding DisplayName}"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </TabItem>

            <TabItem Header="{x:Static resx:ResUI.ProcessListActive}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                        <TextBox
                            x:Name="txtActiveSearch"
                            VerticalContentAlignment="Center"
                            TextChanged="TxtActiveSearch_TextChanged"
                            KeyDown="TxtActiveSearch_KeyDown" />
                        <TextBlock
                            x:Name="txtActiveSearchWatermark"
                            Margin="6,0,0,0"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Foreground="Gray"
                            FontSize="12"
                            Text="输入进程名或搜索..." />
                    </Grid>
                    <StackPanel
                        DockPanel.Dock="Top"
                        Margin="0,0,0,4"
                        Orientation="Horizontal">
                        <Button
                            x:Name="btnAddManual"
                            Margin="0,0,4,0"
                            Padding="8,4"
                            Content="{x:Static resx:ResUI.ProcessListAdd}" />
                        <Button
                            x:Name="btnRemoveSelected"
                            Margin="0,0,8,0"
                            Padding="8,4"
                            Content="{x:Static resx:ResUI.ProcessListRemove}" />
                        <Separator
                            Margin="4,0"
                            VerticalAlignment="Center"
                            Width="1" />
                        <Button
                            x:Name="btnPresetBrowser"
                            Margin="0,0,4,0"
                            Padding="8,4"
                            ToolTip="chrome, firefox, edge, brave, opera, vivaldi, arc"
                            Content="{x:Static resx:ResUI.ProcessListPresetBrowser}" />
                        <Button
                            x:Name="btnPresetDev"
                            Margin="0,0,4,0"
                            Padding="8,4"
                            ToolTip="VS Code, Cursor, git, node, python, dotnet, claude, curl, wget, powershell"
                            Content="{x:Static resx:ResUI.ProcessListPresetDev}" />
                        <Button
                            x:Name="btnPresetAll"
                            Margin="0,0,4,0"
                            Padding="8,4"
                            Content="{x:Static resx:ResUI.ProcessListPresetAll}" />
                        <Button
                            x:Name="btnImportFolder"
                            Padding="8,4"
                            Content="{x:Static resx:ResUI.ProcessListImportFolder}" />
                    </StackPanel>
                    <ListBox
                        x:Name="lstActiveProcesses"
                        BorderThickness="1"
                        MaxHeight="280"
                        SelectionMode="Extended"
                        ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
